<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="theme-color" content="#080c14"/>
<title>TRANSFORM — تحول الجسم</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&family=Bebas+Neue&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#080c14;--bg2:#0d1320;--bg3:#121926;
  --green:#00ff87;--blue:#00c8ff;--red:#ff3d5a;--orange:#ff8c00;--purple:#a855f7;
  --text:#e8f0fe;--muted:#4a5568;--card:#111827;--border:#1e2d40;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:'Cairo',sans-serif;direction:rtl;min-height:100vh;overflow-x:hidden}

/* NOISE TEXTURE */
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");pointer-events:none;z-index:0;opacity:.4}

@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes glow{0%,100%{box-shadow:0 0 20px var(--green)}50%{box-shadow:0 0 40px var(--green),0 0 80px var(--green)30}}
@keyframes countUp{from{transform:scale(.8);opacity:0}to{transform:scale(1);opacity:1}}

.fade{animation:fadeUp .4s ease both}

/* ── HEADER ── */
header{
  position:relative;padding:32px 20px 24px;text-align:center;
  background:linear-gradient(180deg,#0a1628 0%,var(--bg) 100%);
  border-bottom:1px solid var(--border);overflow:hidden;
}
header::after{
  content:'';position:absolute;top:-60px;left:50%;transform:translateX(-50%);
  width:400px;height:160px;border-radius:50%;
  background:radial-gradient(ellipse,rgba(0,255,135,.08) 0%,transparent 70%);
  pointer-events:none;
}
.app-badge{
  display:inline-flex;align-items:center;gap:6px;
  background:rgba(0,255,135,.08);border:1px solid rgba(0,255,135,.2);
  border-radius:20px;padding:4px 14px;font-size:11px;color:var(--green);
  font-weight:700;letter-spacing:1px;margin-bottom:14px;
}
header h1{font-family:'Bebas Neue',sans-serif;font-size:42px;letter-spacing:3px;line-height:1;
  background:linear-gradient(135deg,#fff 30%,var(--green));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
header p{color:#6b7fa3;font-size:13px;margin-top:6px}

/* STATS BAR */
.stats-bar{
  display:flex;justify-content:center;gap:0;
  background:var(--bg2);border-bottom:1px solid var(--border);
  overflow-x:auto;scrollbar-width:none;
}
.stats-bar::-webkit-scrollbar{display:none}
.stat-item{
  flex:1;min-width:80px;padding:14px 8px;text-align:center;
  border-left:1px solid var(--border);position:relative;
}
.stat-item:last-child{border-left:none}
.stat-num{font-family:'Bebas Neue',sans-serif;font-size:22px;color:var(--green)}
.stat-lbl{font-size:10px;color:var(--muted);margin-top:1px}

/* WEEK SELECTOR */
.week-nav{
  padding:16px;display:flex;gap:8px;overflow-x:auto;scrollbar-width:none;
  background:var(--bg2);border-bottom:1px solid var(--border);
}
.week-nav::-webkit-scrollbar{display:none}
.day-pill{
  flex-shrink:0;padding:10px 16px;border-radius:50px;
  background:var(--bg3);border:1px solid var(--border);
  font-size:12px;font-weight:700;color:var(--muted);
  cursor:pointer;transition:all .2s;font-family:'Cairo',sans-serif;
  text-align:center;min-width:70px;
}
.day-pill.active{background:var(--green);color:#000;border-color:var(--green);
  box-shadow:0 0 20px rgba(0,255,135,.3);}
.day-pill.rest{border-style:dashed;color:#3d4f6a}
.day-pill .day-name{font-size:13px}
.day-pill .day-type{font-size:9px;margin-top:2px;opacity:.7}

/* TABS */
#tabs{display:flex;background:var(--bg2);border-bottom:1px solid var(--border)}
.tab-btn{
  flex:1;padding:13px 4px;font-size:11px;background:transparent;
  border:none;border-bottom:2px solid transparent;color:var(--muted);
  cursor:pointer;font-family:'Cairo',sans-serif;transition:all .2s;line-height:1.5;
}
.tab-btn.active{color:var(--green);border-bottom-color:var(--green);font-weight:700}

/* CONTENT */
#content{padding:16px;max-width:640px;margin:0 auto;position:relative;z-index:1}

/* DAY HEADER CARD */
.day-hero{
  background:linear-gradient(135deg,var(--card) 0%,#0d1f35 100%);
  border:1px solid var(--border);border-radius:20px;padding:20px;
  margin-bottom:16px;position:relative;overflow:hidden;
}
.day-hero::before{
  content:'';position:absolute;top:-30px;left:-30px;width:120px;height:120px;
  border-radius:50%;opacity:.06;
}
.day-hero-top{display:flex;align-items:center;justify-content:space-between}
.day-title{font-family:'Bebas Neue',sans-serif;font-size:30px;letter-spacing:1px}
.day-badge{
  padding:5px 14px;border-radius:20px;font-size:11px;font-weight:800;
  font-family:'Cairo',sans-serif;letter-spacing:.5px;
}
.day-muscles{display:flex;flex-wrap:wrap;gap:6px;margin-top:12px}
.muscle-tag{
  background:rgba(0,255,135,.08);border:1px solid rgba(0,255,135,.15);
  color:var(--green);border-radius:8px;padding:3px 10px;font-size:11px;font-weight:600;
}
.day-stats{display:flex;gap:12px;margin-top:14px}
.d-stat{background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:10px;
  padding:8px 14px;text-align:center;flex:1}
.d-stat-n{font-size:18px;font-weight:900;color:var(--green)}
.d-stat-l{font-size:10px;color:var(--muted)}

/* EXERCISE CARD */
.ex-card{
  background:var(--card);border:1px solid var(--border);border-radius:16px;
  margin-bottom:12px;overflow:hidden;cursor:pointer;
  transition:transform .2s,border-color .2s;
}
.ex-card:hover{transform:translateY(-2px);border-color:var(--green)}
.ex-card.expanded{border-color:var(--green)}
.ex-header{display:flex;align-items:center;gap:14px;padding:16px}
.ex-num{
  width:38px;height:38px;border-radius:10px;display:flex;align-items:center;
  justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:18px;
  color:#000;flex-shrink:0;
}
.ex-info{flex:1}
.ex-name{font-weight:800;font-size:15px;color:#fff}
.ex-sub{font-size:11px;color:var(--muted);margin-top:2px}
.ex-sets{display:flex;gap:6px;align-items:center}
.set-badge{
  background:rgba(255,255,255,.05);border:1px solid var(--border);
  border-radius:6px;padding:3px 8px;font-size:11px;font-weight:700;color:var(--text);
}
.ex-arrow{color:var(--muted);font-size:12px;transition:transform .2s;flex-shrink:0}
.ex-card.expanded .ex-arrow{transform:rotate(180deg)}

/* EXPAND BODY */
.ex-body{display:none;padding:0 16px 16px;border-top:1px solid var(--border)}
.ex-card.expanded .ex-body{display:block;animation:fadeUp .25s ease}
.ex-desc{font-size:13px;color:#8fa3c0;line-height:1.7;margin-bottom:14px;margin-top:12px}
.ex-steps{list-style:none}
.ex-steps li{
  display:flex;gap:10px;margin-bottom:10px;font-size:13px;color:#c5d4e8;line-height:1.5;
}
.ex-steps li::before{
  content:attr(data-n);width:22px;height:22px;border-radius:50%;
  background:var(--green);color:#000;font-weight:900;font-size:11px;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;
}
.tips-box{
  background:rgba(168,85,247,.08);border:1px solid rgba(168,85,247,.2);
  border-radius:10px;padding:12px;margin-top:12px;
}
.tips-box p{font-size:12px;color:#c084fc;line-height:1.6}

/* REST DAY */
.rest-card{
  background:linear-gradient(135deg,var(--card),#0d1a2a);
  border:1px dashed var(--border);border-radius:20px;
  padding:40px 20px;text-align:center;
}
.rest-icon{font-size:60px;margin-bottom:16px}
.rest-card h2{font-size:22px;font-weight:900;color:#4a5568;margin-bottom:8px}
.rest-card p{color:#374151;font-size:13px;line-height:1.7}
.rest-tips{margin-top:20px;display:flex;flex-direction:column;gap:8px;text-align:right}
.rest-tip-item{
  background:rgba(255,255,255,.02);border:1px solid var(--border);
  border-radius:10px;padding:10px 14px;font-size:12px;color:#4b5563;
  display:flex;gap:10px;align-items:center;
}

/* NUTRITION TAB */
.macro-ring-wrap{display:flex;justify-content:center;margin-bottom:20px;position:relative}
.macro-ring-wrap svg{transform:rotate(-90deg)}
.macro-label{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center}
.macro-label .kcal{font-family:'Bebas Neue',sans-serif;font-size:28px;color:var(--green)}
.macro-label .kcal-lbl{font-size:10px;color:var(--muted)}
.macro-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:20px}
.macro-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:14px;text-align:center}
.macro-num{font-family:'Bebas Neue',sans-serif;font-size:26px}
.macro-lbl{font-size:10px;color:var(--muted);margin-top:2px}
.meal-card{
  background:var(--card);border:1px solid var(--border);border-radius:14px;
  padding:16px;margin-bottom:10px;
}
.meal-time{font-size:11px;color:var(--green);font-weight:700;margin-bottom:6px}
.meal-name{font-size:15px;font-weight:800;color:#fff;margin-bottom:4px}
.meal-items{font-size:12px;color:var(--muted);line-height:1.6}
.meal-kcal{float:left;font-family:'Bebas Neue',sans-serif;font-size:20px;color:var(--orange)}

/* PROGRESS TAB */
.progress-section{margin-bottom:24px}
.progress-section h3{font-size:14px;font-weight:700;color:var(--green);margin-bottom:12px;
  display:flex;align-items:center;gap:8px}
.prog-bar-wrap{margin-bottom:10px}
.prog-bar-top{display:flex;justify-content:space-between;font-size:12px;margin-bottom:5px}
.prog-bar-bg{height:8px;background:var(--bg3);border-radius:4px;overflow:hidden}
.prog-bar-fill{height:100%;border-radius:4px;transition:width 1s cubic-bezier(.4,0,.2,1)}
.bmi-card{
  background:var(--card);border:1px solid var(--border);border-radius:16px;
  padding:20px;margin-bottom:16px;
}
.bmi-row{display:flex;gap:10px;margin-bottom:14px}
.bmi-input-wrap{flex:1}
.bmi-input-wrap label{font-size:11px;color:var(--muted);display:block;margin-bottom:4px}
.bmi-input{
  width:100%;background:var(--bg2);border:1px solid var(--border);
  border-radius:8px;padding:10px 12px;color:var(--text);font-size:14px;
  font-family:'Cairo',sans-serif;outline:none;transition:border-color .2s;
}
.bmi-input:focus{border-color:var(--green)}
.bmi-btn{
  width:100%;background:var(--green);color:#000;border:none;border-radius:10px;
  padding:12px;font-weight:900;font-size:14px;cursor:pointer;font-family:'Cairo',sans-serif;
  margin-top:10px;transition:all .2s;
}
.bmi-btn:hover{opacity:.9;transform:translateY(-1px)}
#bmi-result{margin-top:14px;display:none}
.bmi-num{font-family:'Bebas Neue',sans-serif;font-size:48px;text-align:center}
.bmi-cat{text-align:center;font-size:14px;font-weight:700;margin-top:4px}

/* TIPS / INFO CARDS */
.info-card{
  background:var(--card);border:1px solid var(--border);border-radius:14px;
  padding:16px;margin-bottom:10px;display:flex;gap:14px;align-items:flex-start;
}
.info-icon{font-size:24px;flex-shrink:0;margin-top:2px}
.info-title{font-weight:700;font-size:14px;color:#fff;margin-bottom:4px}
.info-body{font-size:12px;color:var(--muted);line-height:1.7}

/* SECTION TITLE */
.sec-title{font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:1px;
  color:var(--green);margin-bottom:14px;display:flex;align-items:center;gap:10px}
.sec-title::after{content:'';flex:1;height:1px;background:var(--border)}

/* FOOTER */
footer{text-align:center;padding:24px 16px 40px;color:var(--muted);font-size:11px;
  border-top:1px solid var(--border);margin-top:20px;position:relative;z-index:1}
</style>
</head>
<body>

<header>
  <div class="app-badge">💪 BODY TRANSFORMATION</div>
  <h1>تحول الجسم</h1>
  <p>إنقاص الوزن + بناء العضلات — برنامج 12 أسبوع</p>
</header>

<div class="stats-bar">
  <div class="stat-item"><div class="stat-num">7</div><div class="stat-lbl">أيام/أسبوع</div></div>
