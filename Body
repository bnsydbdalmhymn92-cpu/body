function renderTips(){
  return `
    <div class="sec-title">نصائح الاحتراف</div>
    ${TIPS.map((t,i)=>`
      <div class="info-card fade" style="animation-delay:${i*.06}s">
        <div class="info-icon">${t.icon}</div>
        <div>
          <div class="info-title">${t.title}</div>
          <div class="info-body">${t.body}</div>
        </div>
      </div>`).join('')}`;
}

