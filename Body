<!-- WEEK DAYS -->
<div class="week-nav" id="weekNav"></div>

<!-- TABS -->
<div id="tabs">
  <button class="tab-btn active" onclick="setTab('schedule')">📅<br>الجدول</button>
  <button class="tab-btn" onclick="setTab('nutrition')">🥗<br>التغذية</button>
  <button class="tab-btn" onclick="setTab('progress')">📊<br>التقدم</button>
  <button class="tab-btn" onclick="setTab('tips')">💡<br>نصائح</button>
</div>

<div id="content"></div>
<footer>💪 الاتساق هو المفتاح — لا يوم بلا حركة</footer>

