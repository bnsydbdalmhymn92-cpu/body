let curDay = new Date().getDay(); // 0=Sun
let curTab = 'schedule';
let expandedEx = null;

// ══════════════════════════════════════════════════════
// INIT WEEK NAV
// ══════════════════════════════════════════════════════
function initWeekNav(){
  const nav = document.getElementById('weekNav');
  nav.innerHTML = DAYS.map((d,i)=>`
    <div class="day-pill ${i===curDay?'active':''} ${d.isRest?'rest':''}" onclick="setDay(${i})">
      <div class="day-name">${d.short}</div>
      <div class="day-type" style="font-size:8px">${d.isRest?'🛌 راحة':'💪 تمرين'}</div>
    </div>
  `).join('');
}

function setDay(i){
  curDay=i; expandedEx=null;
  document.querySelectorAll('.day-pill').forEach((p,j)=>{
    p.classList.toggle('active',j===i);
  });
  if(curTab==='schedule') render();
}

// ══════════════════════════════════════════════════════
// TABS
// ══════════════════════════════════════════════════════
function setTab(t){
  curTab=t; expandedEx=null;
  document.querySelectorAll('.tab-btn').forEach((b,j)=>{
    const tabs=['schedule','nutrition','progress','tips'];
    b.classList.toggle('active',tabs[j]===t);
  });
  render();
}

// ══════════════════════════════════════════════════════
// RENDER
// ══════════════════════════════════════════════════════
function render(){
  const el=document.getElementById('content');
  el.style.animation='none'; void el.offsetWidth; el.style.animation='fadeUp .35s ease';
  if(curTab==='schedule') el.innerHTML=renderSchedule();
  else if(curTab==='nutrition') el.innerHTML=renderNutrition();
  else if(curTab==='progress') el.innerHTML=renderProgress();
  else if(curTab==='tips') el.innerHTML=renderTips();
}

// ══════════════════════════════════════════════════════
// SCHEDULE
// ══════════════════════════════════════════════════════
function renderSchedule(){
  const d = DAYS[curDay];
  if(d.isRest) return renderRestDay(d);

  const colorMap={'قوة':d.color,'عزل':'#a855f7','مركب':'#ff8c00','عزل':d.color,'تعمير':'#4a5568','بطن':'#a855f7'};
  let exHTML = d.workout.map((ex,i)=>{
    const c = ex.color || d.color;
    return `
    <div class="ex-card ${expandedEx===i?'expanded':''}" id="ex-${i}" onclick="toggleEx(${i})">
      <div class="ex-header">
        <div class="ex-num" style="background:${c}">${i+1}</div>
        <div class="ex-info">
          <div class="ex-name">${ex.name}</div>
          <div class="ex-sub" style="display:flex;gap:8px;align-items:center;margin-top:4px">
            <span style="color:${c};font-weight:700;font-size:11px">${ex.cat}</span>
            <span style="color:#2d3748">•</span>
            <span class="set-badge">${ex.sets}</span>
            <span class="set-badge">راحة: ${ex.rest}</span>
          </div>
        </div>
        <div class="ex-arrow">▼</div>
      </div>
      <div class="ex-body">
        <p class="ex-desc">${ex.desc}</p>
        <ul class="ex-steps">
          ${ex.steps.map((s,si)=>`<li data-n="${si+1}">${s}</li>`).join('')}
        </ul>
        <div class="tips-box">
          <p>💡 <strong>نصيحة المدرب:</strong> ${ex.tip}</p>
        </div>
      </div>
    </div>`;
  }).join('');

  const muscleTags = d.muscles.map(m=>`<span class="muscle-tag">${m}</span>`).join('');
  return `
    <div class="day-hero fade">
      <div class="day-hero-top">
        <div>
          <div style="font-size:11px;color:${d.color};font-weight:700;margin-bottom:4px">${d.name}</div>
          <div class="day-title" style="color:#fff">${d.type}</div>
        </div>
        <div class="day-badge" style="background:${d.color}18;color:${d.color};border:1px solid ${d.color}30">
          ${d.exercises} تمرين
        </div>
      </div>
      <div class="day-muscles">${muscleTags}</div>
      <div class="day-stats">
        <div class="d-stat">
          <div class="d-stat-n" style="color:${d.color}">${d.burnKcal}</div>
          <div class="d-stat-l">سعرة محروقة</div>
        </div>
        <div class="d-stat">
          <div class="d-stat-n" style="color:${d.color}">${d.exercises}</div>
          <div class="d-stat-l">تمرين</div>
        </div>
        <div class="d-stat">
          <div class="d-stat-n" style="color:${d.color}">~75</div>
          <div class="d-stat-l">دقيقة</div>
        </div>
      </div>
    </div>
    <div class="sec-title">التمارين</div>
    ${exHTML}`;
}

function toggleEx(i){
  expandedEx = expandedEx===i ? null : i;
  render();
}

function renderRestDay(d){
  return `
    <div class="rest-card fade">
      <div class="rest-icon">${d.type==='راحة تامة'?'🛌':'🚶'}</div>
      <h2>${d.type}</h2>
      <p style="color:#4b5563">${d.type==='راحة تامة'?'استرح بالكامل اليوم. جسمك يبني العضلات أثناء الراحة — ليس أثناء التمرين':'حركة خفيفة فقط. راحة نشطة أفضل من الخمول التام'}</p>
      <div class="rest-tips">
        <div class="rest-tip-item">🚶 مشي 20-30 دقيقة خفيفة</div>
        <div class="rest-tip-item">🧘 تمدد وإطالة العضلات</div>
        <div class="rest-tip-item">💧 اشرب الماء بكمية أكبر</div>
        <div class="rest-tip-item">😴 نم ساعة إضافية</div>
        <div class="rest-tip-item">🥗 حافظ على التغذية — لا تبالغ في الأكل</div>
      </div>
    </div>`;
}

// ══════════════════════════════════════════════════════
// NUTRITION
// ══════════════════════════════════════════════════════
function renderNutrition(){
  const meals = NUTRITION.meals.map(m=>`
    <div class="meal-card fade">
      <div class="meal-time">${m.time}</div>
      <div class="meal-name">${m.name} <span class="meal-kcal">${m.kcal}</span></div>
      <div class="meal-items">${m.items}</div>
    </div>`).join('');

  return `
    <div class="sec-title">الماكروز اليومية</div>
    <div class="macro-grid">
      <div class="macro-card fade">
        <div class="macro-num" style="color:#00ff87">${NUTRITION.protein}g</div>
        <div class="macro-lbl">بروتين</div>
      </div>
      <div class="macro-card fade">
        <div class="macro-num" style="color:#00c8ff">${NUTRITION.carbs}g</div>
        <div class="macro-lbl">كربوهيدرات</div>
      </div>
      <div class="macro-card fade">
        <div class="macro-num" style="color:#ff8c00">${NUTRITION.fat}g</div>
        <div class="macro-lbl">دهون</div>
      </div>
    </div>
    <div style="background:var(--card);border:1px solid var(--border);border-radius:14px;padding:14px;margin-bottom:16px;text-align:center">
      <div style="font-family:'Bebas Neue',sans-serif;font-size:36px;color:var(--green)">${NUTRITION.kcal}</div>
      <div style="font-size:11px;color:var(--muted)">سعرة حرارية يومياً (هدف إعادة التركيب)</div>
    </div>
    <div class="sec-title">خطة الوجبات</div>
    ${meals}
    <div class="info-card fade" style="margin-top:8px">
      <div class="info-icon">⚠️</div>
      <div>
        <div class="info-title">ملاحظة مهمة</div>
        <div class="info-body">هذه الأرقام تقريبية لشخص 75-80 كيلو. عدّل الكميات حسب وزنك الحالي وهدفك. استشر أخصائي تغذية للخطة المخصصة.</div>
      </div>
    </div>`;
}

// ══════════════════════════════════════════════════════
// PROGRESS
// ══════════════════════════════════════════════════════
function renderProgress(){
  const bars=[
    {name:"الصدر",pct:72,color:"#00ff87"},
    {name:"الظهر",pct:65,color:"#00c8ff"},
    {name:"الأرجل",pct:58,color:"#ff3d5a"},
    {name:"الأكتاف",pct:70,color:"#a855f7"},
    {name:"الذراعين",pct:80,color:"#ff8c00"},
    {name:"البطن",pct:45,color:"#ffd700"},
  ];
  const barsHTML = bars.map(b=>`
    <div class="prog-bar-wrap">
      <div class="prog-bar-top">
        <span style="color:#c5d4e8;font-size:13px;font-weight:600">${b.name}</span>
        <span style="color:${b.color};font-weight:700">${b.pct}%</span>
      </div>
      <div class="prog-bar-bg">
        <div class="prog-bar-fill" style="width:${b.pct}%;background:linear-gradient(90deg,${b.color}80,${b.color})"></div>
      </div>
    </div>`).join('');

  return `
    <div class="bmi-card fade">
      <div style="font-weight:700;font-size:15px;color:#fff;margin-bottom:14px">🧮 حاسبة BMI</div>
      <div class="bmi-row">
        <div class="bmi-input-wrap">
          <label>الطول (سم)</label>
          <input class="bmi-input" id="height" type="number" placeholder="175" />
        </div>
        <div class="bmi-input-wrap">
          <label>الوزن (كجم)</label>
          <input class="bmi-input" id="weight" type="number" placeholder="80" />
        </div>
      </div>
      <button class="bmi-btn" onclick="calcBMI()">احسب BMI</button>
      <div id="bmi-result">
        <div class="bmi-num" id="bmi-num"></div>
        <div class="bmi-cat" id="bmi-cat"></div>
        <div id="bmi-advice" style="font-size:12px;color:var(--muted);text-align:center;margin-top:8px;line-height:1.6"></div>
      </div>
    </div>
    <div class="sec-title">مستوى التدريب</div>
    <div style="background:var(--card);border:1px solid var(--border);border-radius:14px;padding:16px;margin-bottom:16px">
      ${barsHTML}
    </div>
    <div class="info-card fade">
      <div class="info-icon">📅</div>
      <div>
        <div class="info-title">الجدول الزمني للنتائج</div>
        <div class="info-body">
          <strong style="color:var(--green)">أسبوع 1-2:</strong> تحسن الأداء والقوة<br>
          <strong style="color:var(--blue)">أسبوع 3-4:</strong> بداية تغير الشكل<br>
          <strong style="color:var(--orange)">أسبوع 6-8:</strong> فرق واضح في المرآة<br>
          <strong style="color:var(--purple)">أسبوع 10-12:</strong> تحول حقيقي
        </div>
      </div>
    </div>`;
}

function calcBMI(){
  const h=parseFloat(document.getElementById('height').value);
  const w=parseFloat(document.getElementById('weight').value);
  if(!h||!w||h<100||w<30)return;
  const bmi=(w/((h/100)**2)).toFixed(1);
  const res=document.getElementById('bmi-result');
  const num=document.getElementById('bmi-num');
  const cat=document.getElementById('bmi-cat');
  const adv=document.getElementById('bmi-advice');
  num.textContent=bmi;
  let color,label,advice;
  if(bmi<18.5){color='#00c8ff';label='نقص في الوزن';advice='ركز على زيادة السعرات والبروتين مع التمارين لبناء الكتلة العضلية';}
  else if(bmi<25){color='#00ff87';label='وزن مثالي ✓';advice='ممتاز! ركز على بناء العضلات مع الحفاظ على نسبة الدهون الحالية';}
  else if(bmi<30){color='#ff8c00';label='زيادة في الوزن';advice='خفض 500 سعرة يومياً + هذا البرنامج سيعطيك نتائج ممتازة خلال 12 أسبوع';}
  else{color='#ff3d5a';label='سمنة';advice='ابدأ بكارديو يومي + تمارين المقاومة + استشر طبيباً. أنت في المكان الصحيح!';}
  num.style.color=color; cat.style.color=color; cat.textContent=label; adv.textContent=advice;
  res.style.display='block'; res.style.animation='countUp .4s ease';
}

// ══════════════════════════════════════════════════════
